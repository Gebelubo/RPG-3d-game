# Low-poly house model for RPG3D
# Units: meters  Origin: center bottom
mtllib house.mtl

o house_walls

v -1.0  0.0 -1.0
v  1.0  0.0 -1.0
v  1.0  2.0 -1.0
v -1.0  2.0 -1.0
v -1.0  0.0  1.0
v  1.0  0.0  1.0
v  1.0  2.0  1.0
v -1.0  2.0  1.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

vn  0  0 -1
vn  0  0  1
vn  1  0  0
vn -1  0  0
vn  0  1  0

usemtl wall_material

# Front face
f 1/1/1 2/2/1 3/3/1 4/4/1
# Back face
f 6/1/2 5/2/2 8/3/2 7/4/2
# Right face
f 2/1/3 6/2/3 7/3/3 3/4/3
# Left face
f 5/1/4 1/2/4 4/3/4 8/4/4
# Top face
f 4/1/5 3/2/5 7/3/5 8/4/5

o house_roof

v -1.2  2.0 -1.2
v  1.2  2.0 -1.2
v  0.0  3.2 -0.0
v -1.2  2.0  1.2
v  1.2  2.0  1.2

vt 0.5 1.0
vt 0.0 0.0
vt 1.0 0.0

vn  0  0.7 -0.7
vn  0  0.7  0.7
vn  0.7 0.7  0.0
vn -0.7 0.7  0.0

usemtl roof_material

# Front slope
f 9/10/6 10/11/6 11/12/6
# Back slope
f 12/10/7 13/11/7 11/12/7
# Right slope
f 10/10/8 13/11/8 11/12/8
# Left slope
f 12/10/9 9/11/9 11/12/9
